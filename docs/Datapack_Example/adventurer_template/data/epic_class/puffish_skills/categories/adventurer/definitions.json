    "second_wind": {
        "type": "puffish_skills:default",
        "category_id": "adventurer",
        "title": "Second Wind",
        "description": "Catch your breath in the heat of battle. Grants a burst of regeneration.",
        "icon": {
            "type": "item",
            "data": {
                "item": "minecraft:golden_apple"
            }
        },
        "toggle": true,
        "keybind_slot": 1,
        "cooldown": 600,
        "rewards": [
            {
                "type": "puffish_skill_leveling:toggle",
                "data": {
                    "enable_rewards": [
                        {
                            "type": "puffish_skill_leveling:effect",
                            "data": {
                                "effect": "minecraft:regeneration",
                                "amplifier": 0,
                                "duration": 100,
                                "persistent": false,
                                "is_protected": false
                            }
                        },
                        {
                            "type": "puffish_skills:command",
                            "data": {
                                "command": "title @s actionbar {\"text\":\"Second Wind activated!\",\"color\":\"green\"}"
                            }
                        },
                        {
                            "type": "puffish_skills:command",
                            "data": {
                                "command": "playsound minecraft:entity.player.levelup player @s ~ ~ ~ 0.5 1.5"
                            }
                        }
                    ],
                    "disable_rewards": [
                        {
                            "type": "puffish_skills:command",
                            "data": {
                                "command": "title @s actionbar {\"text\":\"Second Wind cooling down...\",\"color\":\"gray\"}"
                            }
                        }
                    ]
                }
            }
        ],
        "metadata": {
            "icon": "second_wind"
        }
