# Minecraft Development Configuration
# Configuration for testing Pufferfish Skill Leveling addon

# Server Configuration
SERVER_MEMORY=2G
CLIENT_MEMORY=4G

# Mod Versions
MINECRAFT_VERSION=1.20
FABRIC_VERSION=0.14.21
FORGE_VERSION=46.0.14
SKILLS_MOD_VERSION=0.16.3+1.20

# Development Settings
AUTO_COPY_BUILDS=true
ENABLE_DEBUG=true
GAMEMODE=creative
DIFFICULTY=peaceful

# Port Configuration
FABRIC_SERVER_PORT=25565
FORGE_SERVER_PORT=25566

# Testing Configuration
ENABLE_COMMAND_BLOCKS=true
OP_PLAYER_ON_JOIN=true
REDUCED_DEBUG_INFO=false

# Build Configuration
CLEAN_BEFORE_BUILD=false
RUN_TESTS_ON_BUILD=true
AUTO_RESTART_ON_BUILD=false

# Docker Configuration
DOCKER_IMAGE_NAME=minecraft-dev-skillleveling
DOCKER_CONTAINER_NAME=minecraft-dev-skillleveling
DOCKER_AUTO_BUILD=true

# Paths
FABRIC_MODS_DIR=/home/minecraft/fabric-server/mods
FORGE_MODS_DIR=/home/minecraft/forge-server/mods
WORKSPACE_MOUNT=/workspace
